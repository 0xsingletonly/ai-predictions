# Macro Reasoning Agent - Environment Variables

# NewsAPI (get free key at https://newsapi.org/)
NEWSAPI_KEY=your_newsapi_key_here

# Polymarket APIs (optional - public endpoints work without keys)
# POLYMARKET_GAMMA_API_KEY=your_gamma_key_here
# POLYMARKET_CLOB_API_KEY=your_clob_key_here

# Kimi API (for LLM reasoning) - Get key from https://platform.moonshot.cn/
KIMI_API_KEY=your_kimi_api_key_here

# Database (optional - defaults to local SQLite)
# DATABASE_URL=sqlite:///macro_reasoning.db
